# Whatnot Show Monitor v2 — Environment Variables

# Required: Comma-separated Whatnot usernames to monitor
WHATNOT_USERNAMES=ofcchad,anotherbreaker

# Required: Slack Incoming Webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Required: Secret token that GitHub Actions must pass to /run endpoint
# Generate with: openssl rand -hex 32
TRIGGER_SECRET=your-secret-token-here

# Optional: Override state/log file paths (use for Render persistent disk)
# STATE_FILE_PATH=/data/state.json
# LOG_FILE_PATH=/data/debug_logs.json

# Optional: Port (default: 5000)
# PORT=5000
